   :body "name: CI\n\npermissions: {}\n\non:\n  pull_request:\n  push:\n    branches:\n      - main\n      - dev\n  schedule:\n    - cron: '0 2 * * *'\n  workflow_dispatch:\n\nconcurrency:\n  group: ${{ github.workflow }}-${{ github.event.pull_request.number || github.sha }}\n  cancel-in-progress: true\n\njobs:\n  tidy:\n    uses: taiki-e/github-actions/.github/workflows/tidy.yml@6bdbb973f58616e14d2905249e163a0ac857ef24 # main\n    permissions:\n      security-events: write # for github/codeql-action/*\n  miri:\n    needs: tidy\n    uses: taiki-e/github-actions/.github/workflows/rust-miri.yml@6bdbb973f58616e14d2905249e163a0ac857ef24 # main\n  msrv:\n    needs: tidy\n    uses: taiki-e/github-actions/.github/workflows/rust-msrv.yml@6bdbb973f58616e14d2905249e163a0ac857ef24 # main\n  test:\n    needs: tidy\n    uses: taiki-e/github-actions/.github/workflows/rust-test.yml@6bdbb973f58616e14d2905249e163a0ac857ef24 # main\n    with:\n      rust: 1.37,stable,beta,nightly\n      additional-no-std-crates: tests/no-std\n"} {:path ".github/zizmor.yml"
