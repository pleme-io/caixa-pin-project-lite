   :sha256 "8d7e8ec340a8918f07b8f0ec67bd3a6220b6730f7b4f8343d850aa3ebcb36eed"
   :size 654
   :body "// SPDX-License-Identifier: Apache-2.0 OR MIT\n\n#![cfg(nightly)]\n#![no_core]\n#![feature(no_core)]\n\n// Make sure the items generated by pin-project-lite don't depend on paths like\n// `core`, `core::prelude::*`, etc.\n//\n// Note:\n// - pin-project-lite depends on core's items and is not really usable\n//   in a no-core environment.\n\nextern crate core as _core;\n\n// Dummy module to check that the expansion refers to the crate.\nmod pin_project_lite {}\n\npub mod module {\n    use _core::{fmt::Debug, include, prelude::v1::derive};\n\n    include!(\"../include/basic.rs\");\n}\n\nuse _core::{fmt::Debug, include, prelude::v1::derive};\n\ninclude!(\"../include/basic.rs\");\n"} {:path "tests/no-core/build.rs"
   :sha256 "7b1aa2f7ad4007cec613eaa5cc42826de1ba6e451068a14049913ba456679ddf"
   :size 558
   :body "// SPDX-License-Identifier: Apache-2.0 OR MIT\n\nuse std::{env, process::Command};\n\nfn main() {\n    println!(\"cargo:rerun-if-changed=build.rs\");\n    println!(\"cargo:rustc-check-cfg=cfg(nightly)\");\n\n    if is_nightly() {\n        println!(\"cargo:rustc-cfg=nightly\");\n    }\n}\n\nfn is_nightly() -> bool {\n    env::var_os(\"RUSTC\")\n        .and_then(|rustc| Command::new(rustc).arg(\"--version\").output().ok())\n        .and_then(|output| String::from_utf8(output.stdout).ok())\n        .map_or(false, |version| version.contains(\"nightly\") || version.contains(\"dev\"))\n}\n"} {:path "tests/compiletest.rs"
