   :body "// SPDX-License-Identifier: Apache-2.0 OR MIT\n\nuse std::marker::PhantomPinned;\n\nuse pin_project_lite::pin_project;\n\npin_project! {\n    struct Foo<T> {\n        #[pin]\n        inner: T,\n    }\n}\n\nstruct __Origin {}\n\nimpl Unpin for __Origin {}\n\nfn is_unpin<T: Unpin>() {}\n\nfn main() {\n    is_unpin::<Foo<PhantomPinned>>(); //~ ERROR E0277\n}\n"} {:path "tests/ui/pin_project/overlapping_unpin_struct.stderr"
